
rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Manabites — Firestore Security Rules (Production-Ready)
//
// Data model assumed:
//
//   /admins/{uid}               { role: 'admin' }
//   /riders/{phone}             { uid, name, phone, isOnline, activeOrderId, ... }
//   /orders/{orderId}           { status, riderId, restaurantId, customerId, ... }
//   /restaurants/{restaurantId} { name, location, ... }
//   /customers/{customerId}     { uid, name, ... }
//
// Rider docs are keyed by 10-digit phone number (without +91) so the rider
// app and admin panel always read/write the same document.
//
// Access matrix:
//   - Admin    : full read/write on everything
//   - Rider    : read/write own rider doc (limited fields); read/update own orders
//   - Customer : read own orders, create orders
//   - Public   : nothing
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Fetch the caller's admin doc (cached by Firestore runtime)
    function isAdmin() {
      return isAuth()
          && exists(/databases/$(database)/documents/admins/$(uid()))
          && get(/databases/$(database)/documents/admins/$(uid())).data.role == 'admin';
    }

    function isRider(riderId) {
      return isAuth() && uid() == riderId;
    }

    function isCustomer(customerId) {
      return isAuth() && uid() == customerId;
    }

    // True when riderId matches the caller's phone number (with or without +91 prefix)
    function isOwnPhoneDoc(riderId) {
      return isAuth()
          && request.auth.token.phone_number != null
          && (riderId == request.auth.token.phone_number
              || riderId == request.auth.token.phone_number[3:]);
    }

    // Fields a rider is allowed to self-update on a uid-keyed doc (legacy)
    function riderAllowedFields() {
      return [
        'status', 'isOnline', 'isAvailable', 'activeOrderId',
        'location', 'lastLocationUpdate',
        'soundEnabled', 'workArea', 'workAreaLocation',
        'vehicle', 'bankAccount', 'ifsc',
        'totalDeliveries', 'totalEarnings', 'totalDistance', 'totalDistanceKm',
        'todayEarnings', 'weeklyEarnings',
        'updatedAt'
      ];
    }

    function orderClaimAllowedFields() {
      return [
        'riderId', 'riderName', 'riderPhone',
        'status', 'acceptedAt', 'updatedAt', 'deliveryOtp'
      ];
    }

    function orderStatusUpdateAllowedFields() {
      return [
        'riderId', 'status', 'updatedAt',
        'deliveredAt', 'deliveryOtp'
      ];
    }

    // ── Admins ───────────────────────────────────────────────────────────────
    // Only the server (Firebase Admin SDK) writes these; clients only read own.
    match /admins/{adminId} {
      allow read: if isAuth() && uid() == adminId;
      allow write: if false; // admin SDK only
    }

    // ── Riders ───────────────────────────────────────────────────────────────
    match /riders/{riderId} {
      // Read: own uid-keyed doc, own phone-keyed doc, or admin
      allow read: if isRider(riderId)
                 || isAdmin()
                 || isOwnPhoneDoc(riderId);

      // Create:
      //   1. Admin pre-creating a rider doc
      //   2. Rider creating a uid-keyed doc (legacy first-login)
      //   3. Rider creating their phone-keyed doc on first login
      allow create: if isAdmin()
                   || (isRider(riderId) && request.resource.data.uid == riderId)
                   || (isOwnPhoneDoc(riderId) && request.resource.data.uid == uid());

      // Update:
      //   1. Admin — unrestricted
      //   2. Rider updating uid-keyed doc with allowed fields (legacy)
      //   3. Rider updating their own phone-keyed doc — any field EXCEPT protected ones
      allow update: if isAdmin()
                   || (isRider(riderId)
                       && request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasOnly(riderAllowedFields()))
                   || (isOwnPhoneDoc(riderId)
                       && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['approvalStatus', 'approved', 'createdAt']));

      allow delete: if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Read: assigned rider, the ordering customer, admin, OR any rider reading an unclaimed/available order
      allow read: if isAdmin()
                 || (isAuth() && resource.data.riderId == uid())
                 || (isAuth() && resource.data.customerId == uid())
                 || (isAuth() && resource.data.riderId == null && resource.data.status == 'ready');

      // Create: authenticated customer, admin, or a rider claiming a client-side demo order
      allow create: if isAdmin()
                    || (isAuth() && (
                         request.resource.data.customerId == uid()
                         || (request.resource.data.riderId == uid()
                             && request.resource.data.status == 'out_for_delivery')
                       ));

      // Update:
      //   1. Rider claiming an unclaimed order (riderId == null → own uid)
      //   2. Assigned rider updating only allowed status fields
      //   3. Admin unrestricted
      allow update: if isAdmin()
                   || (
                     isAuth()
                     && (
                       (resource.data.riderId == null
                        && request.resource.data.riderId == uid()
                        && request.resource.data.status == 'out_for_delivery'
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(orderClaimAllowedFields()))
                       || (resource.data.riderId == uid()
                           && request.resource.data.riderId == resource.data.riderId
                           && request.resource.data.diff(resource.data)
                                .affectedKeys()
                                .hasOnly(orderStatusUpdateAllowedFields()))
                     )
                   );

      allow delete: if isAdmin();
    }

    // ── Restaurants ──────────────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Any authenticated user can read (riders need address / location)
      allow read: if isAuth();

      // Only admins can create / update restaurant records
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Covers customers, riders, and restaurant owners linked via Firebase Auth.
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAdmin()
                   || (isAuth() && uid() == userId
                       && !request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasAny(['role', 'isActive']));
      allow delete: if isAdmin();
    }

    // ── Rider Notifications ───────────────────────────────────────────────────
    // Admin writes approval/rejection messages; rider app reads own notification.
    match /riderNotifications/{riderId} {
      allow read: if isAdmin() || isOwnPhoneDoc(riderId);
      allow write: if isAdmin();
    }

    // ── Customers ────────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:   if isCustomer(customerId) || isAdmin();
      allow create: if isCustomer(customerId)
                   && request.resource.data.uid == customerId;
      allow update: if (isCustomer(customerId)
                   && request.resource.data.uid == customerId)
                   || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Rider Locations (real-time tracking) ─────────────────────────────────
    match /riderLocations/{locationId} {
      allow read: if isAdmin()
                 || (isAuth() && (locationId == uid() || isOwnPhoneDoc(locationId)));
      allow write: if isAuth()
                  && (locationId == uid() || isOwnPhoneDoc(locationId));
    }

    // ── Delivery Earnings (audit trail) ──────────────────────────────────────
    // Written server-side when an order completes. Riders can only read their own.
    match /earnings/{earningId} {
      allow read: if isAdmin()
                 || (isAuth() && resource.data.riderId == uid());
      allow write: if isAdmin(); // server-side only
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────────
    // Riders create and read their own; only admins can update/delete.
    match /withdrawalRequests/{reqId} {
      allow create: if isAuth()
                   && request.resource.data.riderId == uid()
                   && request.resource.data.status == 'pending';
      allow read:   if isAuth()
                   && (resource.data.riderId == uid() || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Menu Categories ──────────────────────────────────────────────────────
    match /menuCategories/{categoryId} {
      allow read: if isAuth();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }

    // ── Menu Items ────────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      allow read: if isAuth();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == uid());
      allow create: if isAdmin() || isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.userId == uid());
      allow delete: if isAdmin();
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Promo Codes ───────────────────────────────────────────────────────────
    match /promoCodes/{promoId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Banners ───────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Wallets ───────────────────────────────────────────────────────────────
    match /wallets/{walletId} {
      allow read: if isAdmin() || (isAuth() && resource.data.ownerId == uid());
      allow write: if isAdmin();
    }

    // ── Wallet Transactions ────────────────────────────────────────────────────
    match /walletTransactions/{txId} {
      allow read: if isAdmin() || (isAuth() && resource.data.riderId == uid());
      allow write: if isAdmin();
    }

    // ── Payouts ───────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read, write: if isAdmin();
    }

    // ── Commission Ledger ──────────────────────────────────────────────────────
    match /commissionLedger/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Support Tickets ────────────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── SOS Alerts ────────────────────────────────────────────────────────────
    match /sos_alerts/{alertId} {
      allow create: if isAuth();
      allow read, update: if isAdmin();
    }

    // ── Broadcast Notifications ────────────────────────────────────────────────
    match /broadcastNotifications/{notifId} {
      allow read, write: if isAdmin();
    }

    // ── Ratings ───────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if isAdmin() || isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Catch-all: deny everything not matched above ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
