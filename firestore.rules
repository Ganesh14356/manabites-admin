
rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Manabites — Firestore Security Rules (Production-Ready)
//
// Data model assumed:
//
//   /admins/{uid}               { role: 'admin' }
//   /riders/{riderId}           { uid, name, phone, isOnline, activeOrderId, ... }
//   /orders/{orderId}           { status, riderId, restaurantId, customerId, ... }
//   /restaurants/{restaurantId} { name, location, ... }
//   /customers/{customerId}     { uid, name, ... }
//
// Access matrix:
//   - Admin    : full read/write on everything
//   - Rider    : read/write own rider doc (limited fields); read/update own orders
//   - Customer : read own orders, create orders
//   - Public   : nothing
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Fetch the caller's admin doc (cached by Firestore runtime)
    function isAdmin() {
      return isAuth()
          && exists(/databases/$(database)/documents/admins/$(uid()))
          && get(/databases/$(database)/documents/admins/$(uid())).data.role == 'admin';
    }

    function isRider(riderId) {
      return isAuth() && uid() == riderId;
    }

    function isCustomer(customerId) {
      return isAuth() && uid() == customerId;
    }

    // Fields a rider is allowed to self-update
    function riderAllowedFields() {
      return [
        'isOnline', 'isAvailable', 'activeOrderId',
        'location', 'lastLocationUpdate',
        'soundEnabled', 'workArea',
        'vehicle', 'bankAccount', 'ifsc',
        'totalDeliveries', 'totalEarnings', 'totalDistance',
        'updatedAt'
      ];
    }

    function orderClaimAllowedFields() {
      return [
        'riderId', 'riderName', 'riderPhone',
        'status', 'acceptedAt', 'updatedAt', 'deliveryOtp'
      ];
    }

    function orderStatusUpdateAllowedFields() {
      return [
        'riderId', 'status', 'updatedAt',
        'deliveredAt', 'deliveryOtp'
      ];
    }

    // ── Admins ───────────────────────────────────────────────────────────────
    // Only the server (Firebase Admin SDK) writes these; clients only read own.
    match /admins/{adminId} {
      allow read: if isAuth() && uid() == adminId;
      allow write: if false; // admin SDK only
    }

    // ── Riders ───────────────────────────────────────────────────────────────
    match /riders/{riderId} {
      // Read: own doc, admin, or phone-keyed doc (for first-login migration)
      // Phone auth gives +91XXXXXXXXXX; doc may be keyed as XXXXXXXXXX (10-digit)
      allow read: if isRider(riderId)
                 || isAdmin()
                 || (isAuth()
                     && request.auth.token.phone_number != null
                     && (riderId == request.auth.token.phone_number
                         || riderId == request.auth.token.phone_number[3:]));

      // Create: own doc (first login via RiderContext.initRider)
      allow create: if isRider(riderId)
                   && request.resource.data.uid == riderId;

      // Update: own doc restricted to allowed fields, or admin unrestricted
      allow update: if isAdmin()
                   || (isRider(riderId)
                       && request.resource.data.diff(resource.data)
                            .affectedKeys()
                            .hasOnly(riderAllowedFields()));

      allow delete: if isAdmin();
    }

    // ── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Read: assigned rider, the ordering customer, admin, OR any rider reading an unclaimed/available order
      allow read: if isAdmin()
                 || (isAuth() && resource.data.riderId == uid())
                 || (isAuth() && resource.data.customerId == uid())
                 || (isAuth() && resource.data.riderId == null && resource.data.status == 'ready');

      // Create: authenticated customer, admin, or a rider claiming a client-side demo order
      allow create: if isAdmin()
                    || (isAuth() && (
                         request.resource.data.customerId == uid()
                         || (request.resource.data.riderId == uid()
                             && request.resource.data.status == 'out_for_delivery')
                       ));

      // Update:
      //   1. Rider claiming an unclaimed order (riderId == null → own uid)
      //   2. Assigned rider updating only allowed status fields
      //   3. Admin unrestricted
      allow update: if isAdmin()
                   || (
                     isAuth()
                     && (
                       (resource.data.riderId == null
                        && request.resource.data.riderId == uid()
                        && request.resource.data.status == 'out_for_delivery'
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(orderClaimAllowedFields()))
                       || (resource.data.riderId == uid()
                           && request.resource.data.riderId == resource.data.riderId
                           && request.resource.data.diff(resource.data)
                                .affectedKeys()
                                .hasOnly(orderStatusUpdateAllowedFields()))
                     )
                   );

      allow delete: if isAdmin();
    }

    // ── Restaurants ──────────────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // Any authenticated user can read (riders need address / location)
      allow read: if isAuth();

      // Only admins can create / update restaurant records
      allow write: if isAdmin();
    }

    // ── Customers ────────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:   if isCustomer(customerId) || isAdmin();
      allow create: if isCustomer(customerId)
                   && request.resource.data.uid == customerId;
      allow update: if (isCustomer(customerId)
                   && request.resource.data.uid == customerId)
                   || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Delivery Earnings (audit trail) ──────────────────────────────────────
    // Written server-side when an order completes. Riders can only read their own.
    match /earnings/{earningId} {
      allow read: if isAdmin()
                 || (isAuth() && resource.data.riderId == uid());
      allow write: if isAdmin(); // server-side only
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────────
    // Riders create and read their own; only admins can update/delete.
    match /withdrawalRequests/{reqId} {
      allow create: if isAuth()
                   && request.resource.data.riderId == uid()
                   && request.resource.data.status == 'pending';
      allow read:   if isAuth()
                   && (resource.data.riderId == uid() || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Catch-all: deny everything not matched above ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
