# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ── Restaurant app admin preview ──────────────────────────────────
# URL of the restaurant app (no trailing slash)
# e.g. https://restarent.vercel.app
VITE_RESTAURANT_APP_URL=

# Secret key shared between admin panel and restaurant app for admin preview access
# Set the same value in the restaurant app's VITE_ADMIN_VIEW_KEY
VITE_ADMIN_VIEW_KEY=manabites_admin_2024
